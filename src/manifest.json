{
  "manifest_version": 3,
  "name": "KoalaClicker",
  "version": "1.2.7",
  "description": "A modern, privacy-focused auto-clicker for idle games and web tasks.",
  "icons": {
    "16": "assets/Logo_Cut_16.png",
    "48": "assets/Logo_Cut_48.png",
    "128": "assets/Logo_Cut_128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/Logo_Cut_16.png",
      "48": "assets/Logo_Cut_48.png",
      "128": "assets/Logo_Cut_128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/bypass.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
