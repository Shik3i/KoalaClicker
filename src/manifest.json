{
  "manifest_version": 3,
  "name": "KoalaClicker",
  "version": "1.0.0",
  "description": "A modern, privacy-focused auto-clicker for idle games and web tasks.",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ]
}
